param(
    [Parameter(Mandatory=$true)]
    [string]$Name,

    [Parameter(Mandatory=$true)]
    [string]$Slug
)

$ConfigPath = "C:\Workspace\mdw-toolkit\Config\mdw.json"
$Config = Get-Content $ConfigPath | ConvertFrom-Json

$ProjectPath = Join-Path $Config.Plugins $Slug

if (Test-Path $ProjectPath) {
    Write-Host "Project already exists: $ProjectPath" -ForegroundColor Yellow
    exit 1
}

New-Item -ItemType Directory -Force -Path `
"$ProjectPath\docs", `
"$ProjectPath\includes", `
"$ProjectPath\assets", `
"$ProjectPath\languages", `
"$ProjectPath\templates", `
"$ProjectPath\tests" | Out-Null

@"
# $Name

Plugin slug: $Slug
"@ | Set-Content "$ProjectPath\README.md" -Encoding UTF8

@"
# Project

## Plugin Name

$Name

## Plugin Slug

$Slug

## Maintainer

Murat Özden
"@ | Set-Content "$ProjectPath\PROJECT.md" -Encoding UTF8

@"
# Changelog

## 0.1.0

Initial development version.
"@ | Set-Content "$ProjectPath\CHANGELOG.md" -Encoding UTF8

@"
vendor/
node_modules/
*.zip
*.log
.DS_Store
Thumbs.db
"@ | Set-Content "$ProjectPath\.gitignore" -Encoding UTF8

@"
<?php
/**
 * Plugin Name: $Name
 * Description: WordPress plugin scaffold generated by MDW Toolkit.
 * Version: 0.1.0
 * Author: Murat Özden
 * Text Domain: $Slug
 * Requires at least: 6.5
 * Requires PHP: 7.4
 * License: GPL-2.0-or-later
 */

if ( ! defined( 'ABSPATH' ) ) {
    exit;
}
"@ | Set-Content "$ProjectPath\$Slug.php" -Encoding UTF8

@"
# Product Specification

## Problem

## Target User

## Core Features
"@ | Set-Content "$ProjectPath\docs\product-spec.md" -Encoding UTF8

@"
# UI Specification

## Admin Page

## Menu Location

## Sections
"@ | Set-Content "$ProjectPath\docs\ui-spec.md" -Encoding UTF8

@"
# Release Checklist

- [ ] Git working tree is clean.
- [ ] Version number updated.
- [ ] Plugin Check completed.
- [ ] ZIP generated by release script.
"@ | Set-Content "$ProjectPath\docs\release-checklist.md" -Encoding UTF8

Set-Location $ProjectPath
git init | Out-Null
git branch -M main
git add .
git commit -m "chore: initial plugin scaffold" | Out-Null

Write-Host "Plugin created: $ProjectPath" -ForegroundColor Green